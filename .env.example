# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to GitHub

# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/instaclone

# Individual DB connection vars (alternative to DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=instaclone

# Secret used to sign session cookies - use a long random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-very-long-random-secret-key-here

# Port the API server listens on
PORT=8080
